# Application Environment Variables
NODE_ENV=development

# Domain Configuration
VITE_APP_DOMAIN=nexus-frontend.com
VITE_APP_DEV_DOMAIN=dev.nexus-frontend.com

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=10000

# Authentication
VITE_AUTH_DOMAIN=your-auth-domain.auth0.com
VITE_AUTH_CLIENT_ID=your-client-id
VITE_AUTH_AUDIENCE=your-api-audience

# External Services
VITE_SENTRY_DSN=your-sentry-dsn
VITE_INTERCOM_APP_ID=your-intercom-app-id

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Build Configuration
VITE_APP_NAME=Nexus Frontend
VITE_APP_VERSION=1.0.0

# Development
VITE_DEV_SERVER_PORT=3000
VITE_DEV_SERVER_HOST=0.0.0.0
